# Database files (personal data) — DO NOT relax these patterns
*.db
*.db-shm
*.db-wal
*.db.backup-shm
*.db.backup-wal
*.db.bak
*.db.bak-*
*.db.bak.*

# Native extension binaries (download from releases)
lib/

# Dependencies
node_modules/

# Environment files (may contain API keys)
.env*

# Misc
*.zip

# Lockfile (library — consumers resolve their own deps)
package-lock.json

# Local migrate overrides (machine-specific project list)
mneme.migrate.local.json

# Local scratch — dry-run reports, migration candidate exports, one-off batches
*.tmp.json
*-candidates.json
staging/
